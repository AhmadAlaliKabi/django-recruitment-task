# Purpose:
#   Ignore generated/local files that should not be committed.
#
# Connects with:
#   - local dev environment (venv, IDE, db artifacts)
#   - git workflow cleanliness

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Django
*.log
db.sqlite3
media/
staticfiles/

# Virtual environment
venv/
env/
.venv/

# IDEs
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Misc
*.sqlite3
*.sqlite3-journal

# Celery Beat
celerybeat-schedule*
